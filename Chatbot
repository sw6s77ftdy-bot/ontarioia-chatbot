  .header-info p  { color:var(--gold-light); font-size:11px; font-weight:300; margin-top:2px; }
  .header-logo { font-size:10px; color:var(--gray); text-align:left; line-height:1.5; }
  .header-logo span { display:block; color:var(--gold); font-weight:700; font-size:12px; }
  .messages {
    flex:1; overflow-y:auto; padding:16px 13px;
    display:flex; flex-direction:column; gap:10px; scroll-behavior:smooth;
  }
  .messages::-webkit-scrollbar { width:3px; }
  .messages::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.1); border-radius:4px; }
  .msg { display:flex; gap:8px; max-width:93%; animation:fadeIn 0.3s ease; }
  @keyframes fadeIn {
    from { opacity:0; transform:translateY(8px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .msg.bot  { align-self:flex-end; flex-direction:row-reverse; }
  .msg.user { align-self:flex-start; }
  .msg-av {
    width:29px; height:29px; border-radius:50%;
    background:linear-gradient(135deg,var(--teal),var(--teal-light));
    display:flex; align-items:center; justify-content:center;
    font-size:13px; flex-shrink:0; margin-top:4px;
  }
  .msg-av.u { background:rgba(255,255,255,0.1); }
  .bubble {
    padding:11px 15px; border-radius:18px;
    font-size:13.5px; line-height:1.75; color:var(--text-light);
  }
  .msg.bot  .bubble { background:var(--bubble-bot); border-radius:18px 4px 18px 18px; border:1px solid rgba(255,255,255,0.06); }
  .msg.user .bubble { background:var(--bubble-user); border-radius:4px 18px 18px 18px; color:#fff; font-weight:500; }
  .qr-wrap {
    display:flex; flex-direction:column; gap:7px;
    margin-top:6px; align-items:flex-end;
    align-self:flex-end; max-width:97%;
    animation:fadeIn 0.35s ease;
  }
  .qr {
    background:rgba(26,124,110,0.14); border:1px solid rgba(26,124,110,0.5);
    color:var(--teal-light); padding:9px 15px; border-radius:20px;
    font-family:'Vazirmatn',sans-serif; font-size:13px;
    cursor:pointer; transition:all 0.2s; text-align:right;
  }
  .qr:hover { background:var(--teal); border-color:var(--teal); color:#fff; transform:translateX(2px); }
  .qr.gold  { background:rgba(200,151,58,0.13); border-color:rgba(200,151,58,0.55); color:var(--gold-light); }
  .qr.gold:hover { background:var(--gold); border-color:var(--gold); color:#fff; }
  .qr.cta   { background:linear-gradient(135deg,var(--teal),var(--teal-light)); border:none; color:#fff; font-weight:600; box-shadow:0 4px 14px rgba(26,124,110,0.4); }
  .qr.cta:hover { transform:translateX(2px) translateY(-1px); box-shadow:0 6px 20px rgba(26,124,110,0.5); }
  .typing {
    display:flex; gap:5px; align-items:center;
    padding:11px 15px; background:var(--bubble-bot);
    border-radius:18px 4px 18px 18px; border:1px solid rgba(255,255,255,0.06);
    width:fit-content; align-self:flex-end;
  }
  .typing span { width:7px; height:7px; background:var(--teal-light); border-radius:50%; animation:bounce 1.2s infinite; }
  .typing span:nth-child(2) { animation-delay:0.2s; }
  .typing span:nth-child(3) { animation-delay:0.4s; }
  @keyframes bounce {
    0%,80%,100% { transform:translateY(0); opacity:0.5; }
    40%          { transform:translateY(-6px); opacity:1; }
  }
  .divider {
    text-align:center; color:var(--gray); font-size:11px;
    position:relative; margin:2px 0;
  }
  .divider::before,.divider::after {
    content:''; position:absolute; top:50%; width:34%; height:1px; background:rgba(255,255,255,0.08);
  }
  .divider::before { right:0; } .divider::after { left:0; }
</style>
</head>
