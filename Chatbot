const msgEl = document.getElementById(‘messages’);
function scroll(){ msgEl.scrollTop = msgEl.scrollHeight; }

function showTyping(){
const t=document.createElement(‘div’); t.className=‘typing’; t.id=‘typing’;
t.innerHTML=’<span></span><span></span><span></span>’;
msgEl.appendChild(t); scroll();
}
function hideTyping(){ const t=document.getElementById(‘typing’); if(t)t.remove(); }

function addMsg(text,isUser=false){
const w=document.createElement(‘div’); w.className=`msg ${isUser?'user':'bot'}`;
const av=document.createElement(‘div’); av.className=‘msg-av’+(isUser?’ u’:’’);
av.textContent=isUser?‘👤’:‘🌿’;
const b=document.createElement(‘div’); b.className=‘bubble’;
b.innerHTML=text.replace(/\n/g,’<br>’).replace(/**(.*?)**/g,’<strong>$1</strong>’);
w.appendChild(av); w.appendChild(b); msgEl.appendChild(w); scroll();
}

function addReplies(replies){
const w=document.createElement(‘div’); w.className=‘qr-wrap’;
replies.forEach(r=>{
const btn=document.createElement(‘button’);
btn.className=‘qr’+(r.s===‘gold’?’ gold’:r.s===‘cta’?’ cta’:’’);
btn.textContent=r.l; btn.onclick=()=>pick(r); w.appendChild(btn);
});
msgEl.appendChild(w); scroll();
}

function pick(r){ addMsg(r.l,true); setTimeout(()=>go(r.n),300); }

function go(key){
const f=F[key]; if(!f) return;
if(f.action){ f.action(); go(f.redirect); return; }
showTyping();
setTimeout(()=>{
hideTyping(); addMsg(f.text);
if(f.replies) setTimeout(()=>addReplies(f.replies),180);
}, 500+Math.random()*400);
}

setTimeout(()=>go(‘welcome’),700);
</script>

